font=('Verdana', 20)

def click_btn_function(event):
    print("Btn clicked")
    b=event.widget
    text=b['text']
    print(text)

    if text=='x':
        textField.insert(END,"*")
        return

    if text == '=':
        try:
            ex = textField.get()
            anser = eval(ex)
            textField.delete(0,END)
            textField.insert(0,anser)
        except Exceptionb as e:
            print("error",e)
            showerror("Error",e)
        return
    textField.insert(END, text)
