def calculate_sc(event):
    print('btn...')
    btn=event.widget
    text=btn['text']
    print(text)
    ex=textField.get()
    answer=''
    if text=='todeg':
        print("cal degree")
        answer=str(m.degrees(float(ex)))
    elif text=='torad':
        print('radian')
        answer = str(m.radians(float(ex)))
    elif text=='x!':
        print('cal fact')
        answer = str(m.factorial(int(ex)))
    elif text=='sin':
        print('cal sin')
        answer = str(m.sin(m.radians(int(ex))))
    elif text=='cos':
        print('cal cos')
        answer = str(m.cos(m.radians(int(ex))))
    elif text=='tan':
        print('cal tan')
        answer = str(m.tan(m.radians(int(ex))))
    elif text=='SQRT':
        print('cal sqrt')
        answer=m.sqrt(int(ex))
    elif text=='pow':
        print('pow')
        base, power = ex.split(',')
        print(base)
        print(power)
        answer=str(m.pow(int(base),int(power)))

    textField.delete(0,END)
    textField.insert(0,answer)


def sc_click():
    global normalcalc
    if normalcalc:
        buttonFrame.pack_forget()
        window.geometry("400x600")
        scFrame.pack(side=TOP,pady=20)
        buttonFrame.pack(side=TOP)

        print("show sc")
        normalcalc=False
    else:
        print('normal')
        scFrame.pack_forget()
        window.geometry("400x500")
        normalcalc=True
    print('clicked')

